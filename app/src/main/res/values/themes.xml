<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.BioLogger" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Main Brand Colors: Cyber-Organic Palette -->
        <item name="colorPrimary">#00E676</item> <!-- Neon Green -->
        <item name="colorOnPrimary">#000000</item>
        <item name="colorSurface">#0A0B10</item> <!-- Deep Night -->
        <item name="colorOnSurface">#E0E0E0</item>
        <item name="colorSurfaceVariant">#1A1C2E</item>
        <item name="colorOnSurfaceVariant">#B0B0B0</item>
        <item name="android:windowBackground">#0A0B10</item>

        <!-- Status & Nav Bars -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Typography: Uniform, Clean, Professional -->
        <item name="textAppearanceHeadlineLarge">@style/ScientificHeadline</item>
        <item name="textAppearanceTitleMedium">@style/ScientificTitle</item>
        <item name="textAppearanceBodyMedium">@style/ScientificBody</item>
        <item name="textAppearanceLabelSmall">@style/ScientificLabel</item>
    </style>

    <style name="ScientificHeadline" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">28sp</item>
    </style>

    <style name="ScientificTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#00E676</item> <!-- Accent Color -->
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="ScientificBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">#B0B0B0</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="ScientificLabel" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textColor">#00E676</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#F8F9FA</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.BioLogger</item>
    </style>

    <style name="GlassCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">#1A1C2E</item> <!-- Translucent appearance -->
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">#30344F</item>
        <item name="strokeWidth">1dp</item>
        <item name="shapeAppearance">@style/ScientificShape</item>
    </style>

    <style name="ScientificShape" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">12dp</item>
    </style>
</resources>
