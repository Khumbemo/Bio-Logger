        <action android:id="@+id/action_gardenHomeFragment_to_planningCalendarFragment" app:destination="@id/planningCalendarFragment" />
    </fragment>

    <fragment android:id="@+id/seasonalPlannerFragment" android:name="com.biologger.garden.SeasonalPlannerFragment" android:label="Seasonal Planner" />
    <fragment android:id="@+id/companionPlantingFragment" android:name="com.biologger.garden.CompanionPlantingFragment" android:label="Companion Planting" />
    <fragment android:id="@+id/soilAmendmentFragment" android:name="com.biologger.garden.SoilAmendmentFragment" android:label="Soil pH and Amendment" />
    <fragment android:id="@+id/bedLayoutFragment" android:name="com.biologger.garden.BedLayoutFragment" android:label="Bed Layout Planner" />
    <fragment android:id="@+id/wateringScheduleFragment" android:name="com.biologger.garden.WateringScheduleFragment" android:label="Watering Schedule" />
    <fragment android:id="@+id/compostTrackerFragment" android:name="com.biologger.garden.CompostTrackerFragment" android:label="Composting Tracker" />
    <fragment android:id="@+id/pestIdFragment" android:name="com.biologger.garden.PestIdFragment" android:label="Pest Identifier" />
    <fragment android:id="@+id/yieldRecorderFragment" android:name="com.biologger.garden.YieldRecorderFragment" android:label="Yield Recorder" />
    <fragment android:id="@+id/yieldEstimationFragment" android:name="com.biologger.garden.YieldEstimationFragment" android:label="Yield Estimation" />
    <fragment android:id="@+id/plantWikiFragment" android:name="com.biologger.garden.PlantWikiFragment" android:label="Plant Wiki" />
    <fragment android:id="@+id/planningCalendarFragment" android:name="com.biologger.garden.PlanningCalendarFragment" android:label="Planning Calendar" />

    <fragment android:id="@+id/noteVaultHomeFragment" android:name="com.biologger.notevault.NoteVaultHomeFragment" android:label="Note Vault" tools:layout="@layout/fragment_note_vault_home">
        <action android:id="@+id/action_noteVaultHomeFragment_to_newNoteFragment" app:destination="@id/newNoteFragment" />
        <action android:id="@+id/action_noteVaultHomeFragment_to_noteDetailFragment" app:destination="@id/noteDetailFragment" />
    </fragment>

    <fragment android:id="@+id/newNoteFragment" android:name="com.biologger.notevault.NewNoteFragment" android:label="New Note" />
    <fragment android:id="@+id/noteDetailFragment" android:name="com.biologger.notevault.NoteDetailFragment" android:label="Note Details" />

    <fragment
        android:id="@+id/exportCenterFragment"
        android:name="com.biologger.export.ExportCenterFragment"
