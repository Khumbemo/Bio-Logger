        <action android:id="@+id/action_forestHomeFragment_to_crownCoverFragment" app:destination="@id/crownCoverFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_forestHomeFragment_to_litterfallFragment" app:destination="@id/litterfallFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
