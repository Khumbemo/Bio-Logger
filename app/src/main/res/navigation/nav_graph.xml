        <action android:id="@+id/action_greenhouseHomeFragment_to_potExperimentFragment" app:destination="@id/potExperimentFragment" />
        <action android:id="@+id/action_greenhouseHomeFragment_to_potExperimentLoggerFragment" app:destination="@id/potExperimentLoggerFragment" />
        <action android:id="@+id/action_greenhouseHomeFragment_to_climateLogFragment" app:destination="@id/climateLogFragment" />
        <action android:id="@+id/action_greenhouseHomeFragment_to_germinationTrackerFragment" app:destination="@id/germinationTrackerFragment" />
        <action android:id="@+id/action_greenhouseHomeFragment_to_fertilizerCalculatorFragment" app:destination="@id/fertilizerCalculatorFragment" />
        <action android:id="@+id/action_greenhouseHomeFragment_to_irrigationSchedulerFragment" app:destination="@id/irrigationSchedulerFragment" />
        <action android:id="@+id/action_greenhouseHomeFragment_to_pestDiseaseLogFragment" app:destination="@id/pestDiseaseLogFragment" />
        <action android:id="@+id/action_greenhouseHomeFragment_to_harvestRecorderFragment" app:destination="@id/harvestRecorderFragment" />
        <action android:id="@+id/action_greenhouseHomeFragment_to_growthRateFragment" app:destination="@id/growthRateFragment" />
    </fragment>

    <fragment android:id="@+id/potExperimentFragment" android:name="com.biologger.greenhouse.PotExperimentFragment" android:label="Pot Experiment" />
    <fragment android:id="@+id/potExperimentLoggerFragment" android:name="com.biologger.greenhouse.PotExperimentLoggerFragment" android:label="Pot Logger" />
    <fragment android:id="@+id/climateLogFragment" android:name="com.biologger.greenhouse.ClimateLogFragment" android:label="Climate Log" />
    <fragment android:id="@+id/germinationTrackerFragment" android:name="com.biologger.greenhouse.GerminationTrackerFragment" android:label="Germination Tracker" />
    <fragment android:id="@+id/fertilizerCalculatorFragment" android:name="com.biologger.greenhouse.FertilizerCalculatorFragment" android:label="Fertilizer Calculator" />
    <fragment android:id="@+id/irrigationSchedulerFragment" android:name="com.biologger.greenhouse.IrrigationSchedulerFragment" android:label="Irrigation Scheduler" />
    <fragment android:id="@+id/pestDiseaseLogFragment" android:name="com.biologger.greenhouse.PestDiseaseLogFragment" android:label="Pest and Disease" />
    <fragment android:id="@+id/harvestRecorderFragment" android:name="com.biologger.greenhouse.HarvestRecorderFragment" android:label="Harvest Recorder" />
    <fragment android:id="@+id/growthRateFragment" android:name="com.biologger.greenhouse.GrowthRateFragment" android:label="Growth Rate Analyzer" />

    <fragment android:id="@+id/gardenHomeFragment" android:name="com.biologger.garden.GardenHomeFragment" android:label="Garden Scape" tools:layout="@layout/fragment_garden_home">
        <action android:id="@+id/action_gardenHomeFragment_to_seasonalPlannerFragment" app:destination="@id/seasonalPlannerFragment" />
        <action android:id="@+id/action_gardenHomeFragment_to_companionPlantingFragment" app:destination="@id/companionPlantingFragment" />
        <action android:id="@+id/action_gardenHomeFragment_to_soilAmendmentFragment" app:destination="@id/soilAmendmentFragment" />
        <action android:id="@+id/action_gardenHomeFragment_to_bedLayoutFragment" app:destination="@id/bedLayoutFragment" />
