<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.biologger.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_loginFragment_to_mainDashboardFragment"
            app:destination="@id/homeFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.biologger.auth.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register" />

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.biologger.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/toolsFragment"
        android:name="com.biologger.ToolsFragment"
        android:label="Research Tools"
        tools:layout="@layout/fragment_tools">
        <action android:id="@+id/action_toolsFragment_to_forestHomeFragment" app:destination="@id/forestHomeFragment" />
        <action android:id="@+id/action_toolsFragment_to_greenhouseHomeFragment" app:destination="@id/greenhouseHomeFragment" />
        <action android:id="@+id/action_toolsFragment_to_gardenHomeFragment" app:destination="@id/gardenHomeFragment" />
        <action android:id="@+id/action_toolsFragment_to_noteVaultHomeFragment" app:destination="@id/noteVaultHomeFragment" />
    </fragment>

    <fragment
        android:id="@+id/dataFragment"
        android:name="com.biologger.DataFragment"
        android:label="Data Center"
        tools:layout="@layout/fragment_data">
        <action android:id="@+id/action_dataFragment_to_exportCenterFragment" app:destination="@id/exportCenterFragment" />
    </fragment>

    <fragment android:id="@+id/forestHomeFragment" android:name="com.biologger.forest.ForestHomeFragment" android:label="Forest Capture" tools:layout="@layout/fragment_forest_home">
        <action android:id="@+id/action_forestHomeFragment_to_treeMeasurementFragment" app:destination="@id/treeMeasurementFragment" />
        <action android:id="@+id/action_forestHomeFragment_to_basalAreaFragment" app:destination="@id/basalAreaFragment" />
        <action android:id="@+id/action_forestHomeFragment_to_standDensityFragment" app:destination="@id/standDensityFragment" />
        <action android:id="@+id/action_forestHomeFragment_to_timberVolumeFragment" app:destination="@id/timberVolumeFragment" />
        <action android:id="@+id/action_forestHomeFragment_to_biomassFragment" app:destination="@id/biomassFragment" />
        <action android:id="@+id/action_forestHomeFragment_to_treeHealthFragment" app:destination="@id/treeHealthFragment" />
        <action android:id="@+id/action_forestHomeFragment_to_crownCoverFragment" app:destination="@id/crownCoverFragment" />
        <action android:id="@+id/action_forestHomeFragment_to_litterfallFragment" app:destination="@id/litterfallFragment" />
        <action android:id="@+id/action_forestHomeFragment_to_quadratStudiesFragment" app:destination="@id/quadratStudiesFragment" />
        <action android:id="@+id/action_forestHomeFragment_to_transectStudiesFragment" app:destination="@id/transectStudiesFragment" />
        <action android:id="@+id/action_forestHomeFragment_to_gpsAndMappingFragment" app:destination="@id/gpsAndMappingFragment" />
        <action android:id="@+id/action_forestHomeFragment_to_environmentalVariablesFragment" app:destination="@id/environmentalVariablesFragment" />
        <action android:id="@+id/action_forestHomeFragment_to_disturbanceIndexFragment" app:destination="@id/disturbanceIndexFragment" />
        <action android:id="@+id/action_forestHomeFragment_to_digitalHerbariumFragment" app:destination="@id/digitalHerbariumFragment" />
    </fragment>

    <fragment android:id="@+id/treeMeasurementFragment" android:name="com.biologger.forest.TreeMeasurementFragment" android:label="Tree Measurement" />
    <fragment android:id="@+id/basalAreaFragment" android:name="com.biologger.forest.BasalAreaFragment" android:label="Basal Area" />
    <fragment android:id="@+id/standDensityFragment" android:name="com.biologger.forest.StandDensityFragment" android:label="Stand Density" />
    <fragment android:id="@+id/timberVolumeFragment" android:name="com.biologger.forest.TimberVolumeFragment" android:label="Timber Volume" />
    <fragment android:id="@+id/biomassFragment" android:name="com.biologger.forest.BiomassFragment" android:label="Biomass Estimator" />
    <fragment android:id="@+id/treeHealthFragment" android:name="com.biologger.forest.TreeHealthFragment" android:label="Tree Health Log" />
    <fragment android:id="@+id/crownCoverFragment" android:name="com.biologger.forest.CrownCoverFragment" android:label="Crown Cover" />
    <fragment android:id="@+id/litterfallFragment" android:name="com.biologger.forest.LitterfallFragment" android:label="Litterfall Log" />
    <fragment android:id="@+id/quadratStudiesFragment" android:name="com.biologger.forest.QuadratStudiesFragment" android:label="Quadrat Studies" />
