        <action android:id="@+id/action_forestHomeFragment_to_quadratStudiesFragment" app:destination="@id/quadratStudiesFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_forestHomeFragment_to_transectStudiesFragment" app:destination="@id/transectStudiesFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_forestHomeFragment_to_gpsAndMappingFragment" app:destination="@id/gpsAndMappingFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_forestHomeFragment_to_environmentalVariablesFragment" app:destination="@id/environmentalVariablesFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_forestHomeFragment_to_disturbanceIndexFragment" app:destination="@id/disturbanceIndexFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_forestHomeFragment_to_digitalHerbariumFragment" app:destination="@id/digitalHerbariumFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- Forest Tools -->
    <fragment android:id="@+id/treeMeasurementFragment" android:name="com.biologger.forest.TreeMeasurementFragment" android:label="Tree Measurement" />
    <fragment android:id="@+id/basalAreaFragment" android:name="com.biologger.forest.BasalAreaFragment" android:label="Basal Area" />
    <fragment android:id="@+id/standDensityFragment" android:name="com.biologger.forest.StandDensityFragment" android:label="Stand Density" />
    <fragment android:id="@+id/timberVolumeFragment" android:name="com.biologger.forest.TimberVolumeFragment" android:label="Timber Volume" />
    <fragment android:id="@+id/biomassFragment" android:name="com.biologger.forest.BiomassFragment" android:label="Biomass Estimator" />
    <fragment android:id="@+id/treeHealthFragment" android:name="com.biologger.forest.TreeHealthFragment" android:label="Tree Health Log" />
    <fragment android:id="@+id/crownCoverFragment" android:name="com.biologger.forest.CrownCoverFragment" android:label="Crown Cover" />
    <fragment android:id="@+id/litterfallFragment" android:name="com.biologger.forest.LitterfallFragment" android:label="Litterfall Log" />
    <fragment android:id="@+id/quadratStudiesFragment" android:name="com.biologger.forest.QuadratStudiesFragment" android:label="Quadrat Studies" />
    <fragment android:id="@+id/transectStudiesFragment" android:name="com.biologger.forest.TransectStudiesFragment" android:label="Transect Studies" />
    <fragment android:id="@+id/gpsAndMappingFragment" android:name="com.biologger.forest.GpsAndMappingFragment" android:label="GPS and Mapping" />
    <fragment android:id="@+id/environmentalVariablesFragment" android:name="com.biologger.forest.EnvironmentalVariablesFragment" android:label="Environmental Variables" />
    <fragment android:id="@+id/disturbanceIndexFragment" android:name="com.biologger.forest.DisturbanceIndexFragment" android:label="Disturbance Index" />
    <fragment android:id="@+id/digitalHerbariumFragment" android:name="com.biologger.forest.DigitalHerbariumFragment" android:label="Digital Herbarium" />

    <!-- MODULE 2 — AGRO CLIMATIC LAB -->
