    <!-- MODULE 4 — NOTE VAULT -->
    <fragment
        android:id="@+id/noteVaultHomeFragment"
        android:name="com.biologger.notevault.NoteVaultHomeFragment"
        android:label="Note Vault"
        tools:layout="@layout/fragment_note_vault_home">
        <action
            android:id="@+id/action_noteVaultHomeFragment_to_newNoteFragment"
            app:destination="@id/newNoteFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_noteVaultHomeFragment_to_noteDetailFragment"
            app:destination="@id/noteDetailFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/newNoteFragment"
        android:name="com.biologger.notevault.NewNoteFragment"
        android:label="New Note"
        tools:layout="@layout/fragment_new_note" />

    <fragment
        android:id="@+id/noteDetailFragment"
        android:name="com.biologger.notevault.NoteDetailFragment"
        android:label="Note Details"
        tools:layout="@layout/fragment_note_detail">
        <argument
            android:name="noteId"
            app:argType="integer" />
    </fragment>

    <fragment
        android:id="@+id/exportCenterFragment"
        android:name="com.biologger.export.ExportCenterFragment"
        android:label="Export Center"
        tools:layout="@layout/fragment_export_center" />

</navigation>
