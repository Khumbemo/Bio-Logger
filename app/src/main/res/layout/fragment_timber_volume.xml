<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
 xmlns:app="http://schemas.android.com/apk/res-auto"
 android:layout_width="match_parent"
 android:layout_height="match_parent"
 android:fillViewport="true"
 android:overScrollMode="never"
 android:scrollbars="none"
 android:background="@color/surface">

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:padding="16dp">

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="Log Identification"
 style="@style/ScientificLabel"
 android:textColor="@color/forest_green" />

 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="8dp"
 android:hint="Log / Tree ID">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editLogId"
 android:layout_width="match_parent"
 android:layout_height="wrap_content" />
 </com.google.android.material.textfield.TextInputLayout>

 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="8dp"
 android:hint="Species">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editSpecies"
 android:layout_width="match_parent"
 android:layout_height="wrap_content" />
 </com.google.android.material.textfield.TextInputLayout>

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:layout_marginTop="24dp"
 android:text="Dimensions"
 style="@style/ScientificLabel"
 android:textColor="@color/forest_green" />

 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="8dp"
 android:hint="Length (m)">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editLength"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:inputType="numberDecimal" />
 </com.google.android.material.textfield.TextInputLayout>

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="8dp"
 android:orientation="horizontal">
 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="0dp"
 android:layout_height="wrap_content"
 android:layout_weight="1"
 android:layout_marginEnd="4dp"
 android:hint="Base Dia (cm)">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editDBase"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:inputType="numberDecimal" />
 </com.google.android.material.textfield.TextInputLayout>
 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="0dp"
 android:layout_height="wrap_content"
 android:layout_weight="1"
 android:layout_marginHorizontal="4dp"
 android:hint="Mid Dia (cm)">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editDMid"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:inputType="numberDecimal" />
 </com.google.android.material.textfield.TextInputLayout>
 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="0dp"
 android:layout_height="wrap_content"
 android:layout_weight="1"
 android:layout_marginStart="4dp"
 android:hint="Top Dia (cm)">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editDTop"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:inputType="numberDecimal" />
 </com.google.android.material.textfield.TextInputLayout>
 </LinearLayout>

 <com.google.android.material.checkbox.MaterialCheckBox
 android:id="@+id/checkBarkCorrection"
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:layout_marginTop="8dp"
 android:text="Subtract bark thickness" />

 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:id="@+id/layoutBark"

 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:hint="Bark Thickness (cm)"
 android:visibility="gone">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editBark"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:inputType="numberDecimal" />
 </com.google.android.material.textfield.TextInputLayout>

 <com.google.android.material.card.MaterialCardView
 android:id="@+id/cardResults"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="24dp"
 style="@style/GlassCard"
 android:visibility="gone">
 <GridLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:columnCount="2"
 android:padding="20dp">

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="Huber:"
 style="@style/ScientificTitle" />
 <TextView
 android:id="@+id/resHuber"
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:layout_gravity="end"
 style="@style/ScientificTitle" />

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="Smalian:"
 style="@style/ScientificTitle" />
 <TextView
 android:id="@+id/resSmalian"
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:layout_gravity="end"
 style="@style/ScientificTitle" />

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="Newton:"
 style="@style/ScientificTitle" />
 <TextView
 android:id="@+id/resNewton"
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:layout_gravity="end"
 style="@style/ScientificTitle" />

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="Form Factor:"
 style="@style/ScientificTitle" />
 <TextView
 android:id="@+id/resFormFactor"
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:layout_gravity="end"
 style="@style/ScientificTitle" />
 </GridLayout>
 </com.google.android.material.card.MaterialCardView>

 <com.google.android.material.button.MaterialButton
 android:id="@+id/btnCalculateSave"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="24dp"
 android:text="Calculate &amp; Save"
 android:backgroundTint="@color/forest_green" />

 <com.google.android.material.button.MaterialButton
 android:id="@+id/btnClear"
 style="@style/Widget.Material3.Button.TextButton"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:text="Clear"
 android:textColor="@color/text_secondary" />

 </LinearLayout>
</androidx.core.widget.NestedScrollView>
