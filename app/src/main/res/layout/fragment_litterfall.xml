<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
 xmlns:app="http://schemas.android.com/apk/res-auto"
 android:layout_width="match_parent"
 android:layout_height="match_parent"
 android:fillViewport="true"
 android:overScrollMode="never"
 android:scrollbars="none"
 android:background="@color/surface">

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:padding="16dp">

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="Plot Parameters"
 style="@style/ScientificLabel"
 android:textColor="@color/forest_green" />

 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="8dp"
 android:hint="Plot ID">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editPlotId"
 android:layout_width="match_parent"
 android:layout_height="wrap_content" />
 </com.google.android.material.textfield.TextInputLayout>

 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="8dp"
 android:hint="Trap ID">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editTrapId"
 android:layout_width="match_parent"
 android:layout_height="wrap_content" />
 </com.google.android.material.textfield.TextInputLayout>

 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="8dp"
 android:hint="Trap Area (m²)"
 app:helperText="Default: 0.25">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editTrapArea"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:inputType="numberDecimal"
 android:text="0.25" />
 </com.google.android.material.textfield.TextInputLayout>

 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="8dp"
 android:hint="Interval (days)">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editInterval"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:inputType="number" />
 </com.google.android.material.textfield.TextInputLayout>

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="Fresh Mass per Fraction (g)"
 android:layout_marginTop="24dp"
 style="@style/ScientificLabel"
 android:textColor="@color/forest_green" />

 <GridLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:columnCount="2"
 android:layout_marginTop="8dp">
 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="0dp"
 android:layout_height="wrap_content"
 android:layout_columnWeight="1"
 android:layout_marginEnd="4dp"
 android:hint="Leaves">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/massLeaves"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:inputType="numberDecimal" />
 </com.google.android.material.textfield.TextInputLayout>
 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="0dp"
 android:layout_height="wrap_content"
 android:layout_columnWeight="1"
 android:layout_marginStart="4dp"
 android:hint="Twigs">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/massTwigs"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:inputType="numberDecimal" />
 </com.google.android.material.textfield.TextInputLayout>
 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="0dp"
 android:layout_height="wrap_content"
 android:layout_columnWeight="1"
 android:layout_marginEnd="4dp"
 android:layout_marginTop="8dp"
 android:hint="Bark">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/massBark"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:inputType="numberDecimal" />
 </com.google.android.material.textfield.TextInputLayout>
 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="0dp"
 android:layout_height="wrap_content"
 android:layout_columnWeight="1"
 android:layout_marginStart="4dp"
 android:layout_marginTop="8dp"
 android:hint="Other">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/massOther"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:inputType="numberDecimal" />
 </com.google.android.material.textfield.TextInputLayout>
 </GridLayout>

 <com.google.android.material.card.MaterialCardView
 android:id="@+id/cardResults"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="24dp"
 style="@style/GlassCard"
 android:visibility="gone">
 <GridLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:columnCount="2"
 android:padding="20dp">
 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="Rate (g/m²/day):"
 style="@style/ScientificTitle" />
 <TextView
 android:id="@+id/resRate"
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:layout_gravity="end"
 style="@style/ScientificTitle" />

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="Annual Flux (Mg/ha/yr):"
 style="@style/ScientificTitle" />
 <TextView
 android:id="@+id/resFluxMg"
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:layout_gravity="end"
 style="@style/ScientificTitle" />
 </GridLayout>
 </com.google.android.material.card.MaterialCardView>

 <com.google.android.material.button.MaterialButton
 android:id="@+id/btnSave"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="24dp"
 android:text="Calculate &amp; Save"
 android:backgroundTint="@color/forest_green" />

 </LinearLayout>
</androidx.core.widget.NestedScrollView>
