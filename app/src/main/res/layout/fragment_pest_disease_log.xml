<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
 xmlns:app="http://schemas.android.com/apk/res-auto"
 android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true" android:overScrollMode="never" android:scrollbars="none">
 <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Problem Name"><com.google.android.material.textfield.TextInputEditText android:id="@+id/editName" android:layout_width="match_parent" android:layout_height="wrap_content"/></com.google.android.material.textfield.TextInputLayout>
 <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Severity (1-5)" android:layout_marginTop="16dp" />
 <com.google.android.material.slider.Slider android:id="@+id/sliderSeverity" android:layout_width="match_parent" android:layout_height="wrap_content" android:valueFrom="1.0" android:valueTo="5.0" android:stepSize="1.0" android:value="1.0" />
 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:hint="% Plants Affected"><com.google.android.material.textfield.TextInputEditText android:id="@+id/editIncidence" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal"/></com.google.android.material.textfield.TextInputLayout>
 <com.google.android.material.card.MaterialCardView android:id="@+id/cardResults" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" app:cardCornerRadius="16dp" style="@style/GlassCard" app:strokeColor="@color/greenhouse_teal" app:strokeWidth="2dp" android:visibility="gone">
 <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
 <TextView android:id="@+id/resDsi" android:textSize="18sp" android:textStyle="bold" />
 <TextView android:id="@+id/resRisk" android:layout_marginTop="4dp" />
 </LinearLayout>
 </com.google.android.material.card.MaterialCardView>
 <com.google.android.material.button.MaterialButton android:id="@+id/btnSave" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="Log Observation" android:backgroundTint="@color/greenhouse_teal" />
 </LinearLayout>
</androidx.core.widget.NestedScrollView>
