<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
 xmlns:app="http://schemas.android.com/apk/res-auto"
 android:id="@+id/potExperimentScrollView"
 android:layout_width="match_parent"
 android:layout_height="match_parent"
 android:fillViewport="true"
 android:overScrollMode="never"
 android:scrollbars="none"
 android:background="@color/surface">

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:padding="16dp">

 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:hint="Experiment Title">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editTitle"
 android:layout_width="match_parent"
 android:layout_height="wrap_content" />
 </com.google.android.material.textfield.TextInputLayout>

 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="8dp"
 android:hint="Crop">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editCrop"
 android:layout_width="match_parent"
 android:layout_height="wrap_content" />
 </com.google.android.material.textfield.TextInputLayout>

 <GridLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:columnCount="2"
 android:layout_marginTop="8dp">
 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="0dp"
 android:layout_height="wrap_content"
 android:layout_columnWeight="1"
 android:layout_marginEnd="4dp"
 android:hint="Treatments">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editTreatments"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:inputType="number" />
 </com.google.android.material.textfield.TextInputLayout>
 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="0dp"
 android:layout_height="wrap_content"
 android:layout_columnWeight="1"
 android:layout_marginStart="4dp"
 android:hint="Replicates">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editReplicates"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:inputType="number" />
 </com.google.android.material.textfield.TextInputLayout>
 </GridLayout>

 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="8dp"
 android:hint="Randomisation">
 <AutoCompleteTextView
 android:id="@+id/spinnerRandom"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:inputType="none" />
 </com.google.android.material.textfield.TextInputLayout>

 <com.google.android.material.card.MaterialCardView
 android:id="@+id/cardResults"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="24dp"
 app:cardCornerRadius="20dp"
 app:cardElevation="0dp"
 app:strokeWidth="1dp"
 app:strokeColor="#E1E3E8"
 android:visibility="gone">
 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:padding="20dp">
 <TextView
 android:id="@+id/resTotalPots"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:textSize="18sp"
 android:textStyle="bold"
 android:textColor="@color/text_primary" />
 <TextView
 android:id="@+id/resAllocation"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="8dp"
 android:textColor="@color/text_primary" />
 </LinearLayout>
 </com.google.android.material.card.MaterialCardView>

 <com.google.android.material.button.MaterialButton
 android:id="@+id/btnSave"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="24dp"
 android:text="Setup Experiment"
 android:backgroundTint="@color/greenhouse_teal" />
 </LinearLayout>
</androidx.core.widget.NestedScrollView>
