<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
 xmlns:app="http://schemas.android.com/apk/res-auto"
 android:layout_width="match_parent"
 android:layout_height="match_parent"
 android:fillViewport="true"
 android:overScrollMode="never"
 android:scrollbars="none"
 android:background="@color/surface">

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:padding="16dp">

 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:hint="Transect ID">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editTransectId"
 android:layout_width="match_parent"
 android:layout_height="wrap_content" />
 </com.google.android.material.textfield.TextInputLayout>

 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="8dp"
 android:hint="Length (m)">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editLength"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:inputType="numberDecimal" />
 </com.google.android.material.textfield.TextInputLayout>

 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="8dp"
 android:hint="Belt Width (m)">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editWidth"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:inputType="numberDecimal" />
 </com.google.android.material.textfield.TextInputLayout>

 <TextView
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:text="Encounters"
 android:layout_marginTop="24dp"
 android:textStyle="bold"
 android:textColor="@color/forest_green" />

 <androidx.recyclerview.widget.RecyclerView
 android:id="@+id/recyclerEncounters"
 android:layout_width="match_parent"
 android:layout_height="250dp"
 android:layout_marginTop="8dp" />

 <com.google.android.material.button.MaterialButton
 android:id="@+id/btnAddEncounter"
 style="@style/Widget.Material3.Button.OutlinedButton"
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:layout_gravity="center_horizontal"
 android:layout_marginTop="8dp"
 android:text="Add Species Encounter" />

 <com.google.android.material.card.MaterialCardView
 android:id="@+id/cardResults"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="24dp"
 app:cardCornerRadius="20dp"
 app:cardElevation="0dp"
 app:strokeWidth="1dp"
 app:strokeColor="#E1E3E8"
 android:visibility="gone">
 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:padding="20dp">
 <TextView
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:text="Density Summary"
 android:textStyle="bold"
 android:textColor="@color/text_primary" />
 <TextView
 android:id="@+id/resSummary"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="8dp"
 android:textColor="@color/text_primary" />
 </LinearLayout>
 </com.google.android.material.card.MaterialCardView>

 <com.google.android.material.button.MaterialButton
 android:id="@+id/btnSave"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="24dp"
 android:text="Save Study"
 android:backgroundTint="@color/forest_green" />

 </LinearLayout>
</androidx.core.widget.NestedScrollView>
