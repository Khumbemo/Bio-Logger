<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
 xmlns:app="http://schemas.android.com/apk/res-auto"
 android:layout_width="match_parent"
 android:layout_height="match_parent"
 android:overScrollMode="never"
 android:scrollbars="none"
 android:fillViewport="true">

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:padding="16dp">

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="Field Research Suite"
 android:textSize="24sp"
 android:textStyle="bold" />

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="horizontal"
 android:gravity="center_vertical">

 <LinearLayout
 android:layout_width="0dp"
 android:layout_height="wrap_content"
 android:layout_weight="1"
 android:orientation="vertical">
 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:layout_marginTop="4dp"
 android:text="Select a module to begin"
 android:textSize="16sp" />
 </LinearLayout>

 <com.google.android.material.button.MaterialButton
 android:id="@+id/btnNavExport"
 style="@style/Widget.Material3.Button.IconButton"
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 app:icon="@drawable/ic_export"
 android:tooltipText="Export Center" />
 </LinearLayout>

 <!-- Card 1 — Forest Capture -->
 <com.google.android.material.card.MaterialCardView
 android:id="@+id/cardForest"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="24dp"
 app:cardCornerRadius="16dp" style="@style/GlassCard"
 app:cardElevation="2dp"
 android:foreground="@drawable/ripple_card"
 android:clickable="true"
 android:focusable="true">

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="horizontal">

 <View
 android:layout_width="4dp"
 android:layout_height="match_parent"
 android:background="#2E7D32" />

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:padding="16dp">

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="Forest Capture"
 android:textSize="18sp"
 android:textStyle="bold" />

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:layout_marginTop="4dp"
 android:text="Tree surveys, biomass, stand analysis and forest mapping" />
 </LinearLayout>
 </LinearLayout>
 </com.google.android.material.card.MaterialCardView>

 <!-- Card 2 — AgroClimatic Lab -->
 <com.google.android.material.card.MaterialCardView
 android:id="@+id/cardGreenhouse"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="16dp"
 app:cardCornerRadius="16dp" style="@style/GlassCard"
 app:cardElevation="2dp"
 android:foreground="@drawable/ripple_card"
 android:clickable="true"
 android:focusable="true">

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="horizontal">

 <View
 android:layout_width="4dp"
 android:layout_height="match_parent"
 android:background="#00796B" />

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:padding="16dp">

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="AgroClimatic Lab"
 android:textSize="18sp"
 android:textStyle="bold" />

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:layout_marginTop="4dp"
 android:text="Pot experiments, climate monitoring and germination tracking" />
 </LinearLayout>
 </LinearLayout>
 </com.google.android.material.card.MaterialCardView>

 <!-- Card 3 — Garden Scape -->
 <com.google.android.material.card.MaterialCardView
 android:id="@+id/cardGarden"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="16dp"
 app:cardCornerRadius="16dp" style="@style/GlassCard"
 app:cardElevation="2dp"
 android:foreground="@drawable/ripple_card"
 android:clickable="true"
 android:focusable="true">

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="horizontal">

 <View
 android:layout_width="4dp"
 android:layout_height="match_parent"
 android:background="#F57F17" />

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:padding="16dp">

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="Garden Scape"
 android:textSize="18sp"
 android:textStyle="bold" />

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:layout_marginTop="4dp"
 android:text="Seasonal planning, soil analysis, companion planting and yield" />
 </LinearLayout>
 </LinearLayout>
 </com.google.android.material.card.MaterialCardView>

 <!-- Card 4 — Note Vault -->
 <com.google.android.material.card.MaterialCardView
 android:id="@+id/cardNotes"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="16dp"
 android:layout_marginBottom="16dp"
 app:cardCornerRadius="16dp" style="@style/GlassCard"
 app:cardElevation="2dp"
 android:foreground="@drawable/ripple_card"
 android:clickable="true"
 android:focusable="true">

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="horizontal">

 <View
 android:layout_width="4dp"
 android:layout_height="match_parent"
 android:background="#6A1B9A" />

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:padding="16dp">

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="Note Vault"
 android:textSize="18sp"
 android:textStyle="bold" />

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:layout_marginTop="4dp"
 android:text="Record observations, capture photos and annotate field notes" />
 </LinearLayout>
 </LinearLayout>
 </com.google.android.material.card.MaterialCardView>

 </LinearLayout>
</androidx.core.widget.NestedScrollView>
