<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView android:overScrollMode="never" android:scrollbars="none" android:fillViewport="true" xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/textDetailTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:hint="Note Title"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textDetailDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Date Created/Modified"
            android:textSize="12sp"
            android:textColor="@android:color/darker_gray" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipDetailModule"
            style="@style/Widget.MaterialComponents.Chip.Action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:clickable="false"
            android:text="Module" />

        <TextView
            android:id="@+id/textDetailLinkedTool"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Linked tool: None"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/textDetailLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="GPS: Not set"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/editDetailBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@null"
            android:gravity="top"
            android:hint="Full note body..."
            android:inputType="textMultiLine"
            android:minLines="10" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Photo Gallery"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView android:overScrollMode="never" android:scrollbars="none"
            android:id="@+id/recyclerDetailPhotos"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDetailTakePhoto"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:text="Take Photo" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDetailAddPhoto"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:text="Add Photo" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveChanges"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Save Changes" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteNote"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Delete Note"
            android:textColor="@android:color/holo_red_dark" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
