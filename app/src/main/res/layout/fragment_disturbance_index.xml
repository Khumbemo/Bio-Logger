<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
 xmlns:app="http://schemas.android.com/apk/res-auto"
 android:layout_width="match_parent"
 android:layout_height="match_parent"
 android:fillViewport="true"
 android:overScrollMode="never"
 android:scrollbars="none"
 android:background="@color/surface">

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:padding="16dp">

 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:hint="Plot ID">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editPlotId"
 android:layout_width="match_parent"
 android:layout_height="wrap_content" />
 </com.google.android.material.textfield.TextInputLayout>

 <TextView
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:text="Indicators (0-3: None-High)"
 android:layout_marginTop="16dp"
 android:textStyle="bold"
 android:textColor="@color/forest_green" />

 <LinearLayout
 android:id="@+id/layoutIndicators"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:layout_marginTop="8dp" />

 <com.google.android.material.card.MaterialCardView
 android:id="@+id/cardResults"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="24dp"
 app:cardCornerRadius="20dp"
 app:cardElevation="0dp"
 app:strokeWidth="1dp"
 app:strokeColor="#E1E3E8"
 android:visibility="gone">
 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:padding="20dp">
 <TextView
 android:id="@+id/resDiPercent"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:textSize="24sp"
 android:textStyle="bold"
 android:layout_gravity="center_horizontal"
 android:textAlignment="center"
 android:textColor="@color/text_primary" />
 <TextView
 android:id="@+id/resCategory"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_gravity="center_horizontal"
 android:textAlignment="center"
 android:textStyle="bold"
 android:textColor="@color/text_primary" />
 <TextView
 android:id="@+id/resAction"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="8dp"
 android:textAlignment="center"
 android:textColor="@color/text_primary" />
 </LinearLayout>
 </com.google.android.material.card.MaterialCardView>

 <com.google.android.material.button.MaterialButton
 android:id="@+id/btnSave"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="24dp"
 android:text="Calculate &amp; Save"
 android:backgroundTint="@color/forest_green" />

 </LinearLayout>
</androidx.core.widget.NestedScrollView>
