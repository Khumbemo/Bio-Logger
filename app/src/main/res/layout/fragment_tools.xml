<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
 xmlns:app="http://schemas.android.com/apk/res-auto"
 android:layout_width="match_parent"
 android:layout_height="match_parent"
 android:fillViewport="true"
 android:background="@color/surface">

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:padding="24dp">

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="@string/research_tools"
 style="@style/ScientificHeadline" />

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="@string/select_module"
 style="@style/ScientificBody"
 android:layout_marginBottom="32dp"/>

 <!-- Forest Capture -->
 <com.google.android.material.card.MaterialCardView
 android:id="@+id/cardForest"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginBottom="16dp"
 style="@style/GlassCard"
 android:clickable="true"
 android:focusable="true"
 android:foreground="?attr/selectableItemBackground">
 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="horizontal"
 android:padding="20dp"
 android:gravity="center_vertical">
 <FrameLayout
 android:layout_width="48dp"
 android:layout_height="48dp"
 android:background="@drawable/bg_circle_green">
 <ImageView
 android:layout_width="24dp"
 android:layout_height="24dp"
 android:layout_gravity="center"
 android:src="@drawable/ic_forest"
 app:tint="@color/forest_green"
 android:contentDescription="@string/forest_capture"/>
 </FrameLayout>
 <LinearLayout
 android:layout_width="0dp"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:layout_weight="1"
 android:layout_marginStart="16dp">
 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="@string/forest_capture"
 style="@style/ScientificTitle" />
 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="@string/forest_desc"
 style="@style/ScientificBody" />
 </LinearLayout>
 </LinearLayout>
 </com.google.android.material.card.MaterialCardView>

