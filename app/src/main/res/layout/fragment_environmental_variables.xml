<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
 xmlns:app="http://schemas.android.com/apk/res-auto"
 android:layout_width="match_parent"
 android:layout_height="match_parent"
 android:fillViewport="true"
 android:overScrollMode="never"
 android:scrollbars="none"
 android:background="@color/surface">

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:padding="16dp">

 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:hint="Station ID">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editStationId"
 android:layout_width="match_parent"
 android:layout_height="wrap_content" />
 </com.google.android.material.textfield.TextInputLayout>

 <GridLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:columnCount="2"
 android:layout_marginTop="16dp">
 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="0dp"
 android:layout_height="wrap_content"
 android:layout_columnWeight="1"
 android:layout_marginEnd="4dp"
 android:hint="Temp (°C)">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editTemp"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:inputType="numberDecimal" />
 </com.google.android.material.textfield.TextInputLayout>
 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="0dp"
 android:layout_height="wrap_content"
 android:layout_columnWeight="1"
 android:layout_marginStart="4dp"
 android:hint="Humidity (%)">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editHumidity"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:inputType="numberDecimal" />
 </com.google.android.material.textfield.TextInputLayout>
 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="0dp"
 android:layout_height="wrap_content"
 android:layout_columnWeight="1"
 android:layout_marginEnd="4dp"
 android:layout_marginTop="8dp"
 android:hint="Soil pH">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editSoilPh"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:inputType="numberDecimal" />
 </com.google.android.material.textfield.TextInputLayout>
 <com.google.android.material.textfield.TextInputLayout style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 android:layout_width="0dp"
 android:layout_height="wrap_content"
 android:layout_columnWeight="1"
 android:layout_marginStart="4dp"
 android:layout_marginTop="8dp"
 android:hint="Soil Moist (%)">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/editSoilMoist"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:inputType="numberDecimal" />
 </com.google.android.material.textfield.TextInputLayout>
 </GridLayout>

 <com.google.android.material.card.MaterialCardView
 android:id="@+id/cardResults"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="24dp"
 app:cardCornerRadius="20dp"
 app:cardElevation="0dp"
 app:strokeWidth="1dp"
 app:strokeColor="#E1E3E8"
 android:visibility="gone">
 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:padding="20dp">
 <TextView
 android:id="@+id/resVpd"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:textStyle="bold"
 android:textColor="@color/text_primary" />
 <TextView
 android:id="@+id/resSoilStatus"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="4dp"
 android:textColor="@color/text_primary" />
 </LinearLayout>
 </com.google.android.material.card.MaterialCardView>

 <com.google.android.material.button.MaterialButton
 android:id="@+id/btnSave"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="24dp"
 android:text="Calculate &amp; Save"
 android:backgroundTint="@color/forest_green" />

 </LinearLayout>
</androidx.core.widget.NestedScrollView>
